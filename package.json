{
  "name": "imessage-scheduler",
  "private": true,
  "scripts": {
    "dev": "concurrently -n api,gateway,web -c blue,green,magenta \"pnpm --filter @imessage-scheduler/api dev\" \"pnpm --filter @imessage-scheduler/gateway dev\" \"pnpm --filter @imessage-scheduler/web dev\"",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:coverage": "pnpm --filter @imessage-scheduler/api test -- --coverage && pnpm --filter @imessage-scheduler/gateway test -- --coverage && pnpm --filter @imessage-scheduler/web test -- --coverage",
    "test:mutation": "pnpm test:mutation:api && pnpm test:mutation:gateway && pnpm test:mutation:web",
    "test:mutation:api": "pnpm --dir packages/api exec stryker run ../../stryker.conf.mjs --mutate 'src/routes/messages.ts' --testFiles 'tests/messages.test.ts'",
    "test:mutation:gateway": "pnpm --dir packages/gateway exec stryker run ../../stryker.conf.mjs --mutate 'src/delivery-tracker.ts,src/status-tracker.ts' --testFiles 'tests/extract-text.test.ts,tests/delivery-tracker.test.ts'",
    "test:mutation:web": "pnpm --dir packages/web exec stryker run ../../stryker.conf.mjs --mutate 'src/lib/api.ts' --testFiles 'tests/api-client.test.ts'",
    "test:e2e": "pnpm --filter @imessage-scheduler/e2e test",
    "test:e2e:ui": "pnpm --filter @imessage-scheduler/e2e test:ui",
    "test:e2e:api": "pnpm --filter @imessage-scheduler/e2e test:api",
    "test:e2e:browser": "pnpm --filter @imessage-scheduler/e2e test:browser",
    "test:e2e:browser:headed": "pnpm --filter @imessage-scheduler/e2e test:browser:headed",
    "test:e2e:browser:ui": "pnpm --filter @imessage-scheduler/e2e test:browser:ui",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "packageManager": "pnpm@9.15.5"
}
